# Master password to access this website.
NEXT_CURRICULUM_VIEWER_ACCESS_PASSWORD=placeholder
NEXT_CURRICULUM_EDITOR_ACCESS_PASSWORD=placeholder

# Private key used to encrypt our authentication cookie. It has to be at least
# 32 characters long, use https://1password.com/password-generator/ to generate
# it. This can be either a string or an object with incrementing keys like this:
# {2: "...", 1: "..."} to allow for password rotation. iron-session will use
# the highest numbered key for new cookies.
NEXT_CURRICULUM_SESSION_PASSWORD=placeholder_at_least_32_characters_long

# ==============================================================================
# FIREBASE PUBLIC WEB APP CONFIGURATION
# ==============================================================================
# Log in to your Firebase Console at: https://console.firebase.google.com/
# Navigate to Project settings -> General. Under "Your apps", select your Web App
# to view the Firebase SDK snippet configuration parameters.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyA1234567890abcdefghijklmnopqrst
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-gbstem-curriculum.firebaseapp.com
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-12345ABCDE
NEXT_PUBLIC_FIREBASE_MESSAGE_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-gbstem-curriculum
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-gbstem-curriculum.appspot.com

# ==============================================================================
# FIREBASE SERVER-SIDE ADMIN CONFIGURATION (Required for Production Database Writes)
# ==============================================================================
# Generate a service account private key in your Firebase Console:
# Project settings -> Service accounts -> Click "Generate new private key".
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@demo-gbstem.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# ==============================================================================
# FIREBASE EMULATOR CONFIGURATION (Uncomment to use local emulation)
# ==============================================================================
# FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
# FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
# STORAGE_EMULATOR_HOST="127.0.0.1:9199"
